<Window x:Class="DigitalScope.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="Black" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Update available" Style="{StaticResource H1}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TbVersion" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="28" Height="28" Margin="12,0,0,0"
                        Style="{StaticResource DangerIconButton}" Click="BtnClose_Click"/>
            </Grid>

            <Border Grid.Row="1" Margin="0,14,0,12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="12">
                <TextBlock Text="A newer DigitalScope build is ready to download from GitHub."
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Grid.Row="2" Text="Release notes" Style="{StaticResource H2}" Margin="0,0,0,8"/>

            <Border Grid.Row="3"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="10"
                    MinHeight="96" MaxHeight="180">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TbReleaseNotes"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Later" Width="86" Margin="0,0,8,0"
                        Style="{StaticResource GhostButton}" Click="BtnLater_Click"/>
                <Button Content="Update" Width="110"
                        Style="{StaticResource ModernButton}" Click="BtnUpdate_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
