<Window x:Class="DigitalScope.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:DigitalScope.Tabs"
        Title="DigitalScope"
        Icon="/Resources/icon.ico"
        Width="820" Height="700"
        ResizeMode="CanMinimize"
        MinWidth="560" MinHeight="420"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="4,0">
                <RadioButton x:Name="SubTabGeneral"
                             Content="General"
                             GroupName="MainTabs"
                             Tag="General"
                             Style="{StaticResource SubTabButton}"
                             IsChecked="True"
                             Checked="SubTab_Checked"/>
                <RadioButton x:Name="SubTabAppearance"
                             Content="Appearance"
                             GroupName="MainTabs"
                             Tag="Appearance"
                             Style="{StaticResource SubTabButton}"
                             Checked="SubTab_Checked"/>
                <RadioButton x:Name="SubTabHotkeys"
                             Content="Hotkeys"
                             GroupName="MainTabs"
                             Tag="Hotkeys"
                             Style="{StaticResource SubTabButton}"
                             Checked="SubTab_Checked"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <tabs:GeneralTab    x:Name="TabGeneral"    Visibility="Visible"/>
            <tabs:AppearanceTab x:Name="TabAppearance" Visibility="Collapsed"/>
            <tabs:HotkeysTab    x:Name="TabHotkeys"    Visibility="Collapsed"/>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1"
                           x:Name="TbVersion"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
