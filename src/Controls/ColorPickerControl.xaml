<UserControl x:Class="DigitalScope.Controls.ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="248">

    <Border Background="#FF222222"
            BorderBrush="#FF404040"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <StackPanel>

            <Canvas x:Name="SvCanvas" Width="224" Height="150"
                    Cursor="Cross" ClipToBounds="True"
                    MouseLeftButtonDown="SvCanvas_MouseDown"
                    MouseLeftButtonUp="SvCanvas_MouseUp"
                    MouseMove="SvCanvas_MouseMove">
                <Rectangle Width="224" Height="150">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop x:Name="GsHue" Color="Red" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Width="224" Height="150" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="Black" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Ellipse x:Name="SvCursor" Width="12" Height="12"
                         Stroke="White" StrokeThickness="2" Fill="Transparent"
                         Canvas.Left="212" Canvas.Top="-6"
                         IsHitTestVisible="False"/>
            </Canvas>

            <Canvas x:Name="HueCanvas" Width="224" Height="16" Margin="0,8,0,0"
                    Cursor="Hand" ClipToBounds="True"
                    MouseLeftButtonDown="HueCanvas_MouseDown"
                    MouseLeftButtonUp="HueCanvas_MouseUp"
                    MouseMove="HueCanvas_MouseMove">
                <Rectangle Width="224" Height="16" RadiusX="4" RadiusY="4">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF0000" Offset="0"/>
                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                            <GradientStop Color="#00FF00" Offset="0.333"/>
                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                            <GradientStop Color="#0000FF" Offset="0.667"/>
                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                            <GradientStop Color="#FF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle x:Name="HueCursor" Width="4" Height="20"
                           Canvas.Left="-2" Canvas.Top="-2"
                           Fill="White" RadiusX="2" RadiusY="2"
                           IsHitTestVisible="False"/>
            </Canvas>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="ColorPreviewBorder"
                        Width="30" Height="30"
                        CornerRadius="6"
                        Background="Red"
                        Margin="0,0,4,0"/>
                <TextBox x:Name="TbPickerHex"
                         Grid.Column="1"
                         Margin="4,0"
                         Background="#FF1A1A1A"
                         Foreground="#FFEEEEEE"
                         BorderBrush="#FF404040"
                         BorderThickness="1"
                         Padding="6,4"
                         FontSize="12"
                         CaretBrush="#FFEEEEEE"
                         MaxLength="7"
                         TextChanged="TbPickerHex_TextChanged">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
                <Button Grid.Column="2"
                        Content="OK"
                        Height="30"
                        Padding="8,0"
                        FontSize="12"
                        Style="{StaticResource ModernButton}"
                        Click="BtnOk_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
